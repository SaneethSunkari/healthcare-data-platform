          "format": "table",
          "rawQuery": true,
          "rawSql": "with data as (\nselect distinct\n    initcap(coalesce(cp.category, 'care plan')) as \"Category\",\n    left(cp.description, 90) as \"Plan\",\n    initcap(coalesce(cp.status, 'active')) as \"Status\",\n    cp.start_date::date as \"Started\",\n    left(coalesce(cp.activity_summary, ''), 120) as \"Next Step\"\nfrom care_plans cp\njoin patients p on p.id = cp.patient_id\nwhere p.golden_id = '${golden_id}'\n  and coalesce(cp.status, 'active') in ('active', 'draft', 'on-hold')\norder by \"Started\" desc nulls last, \"Plan\"\nlimit 25\n)\nselect * from data\nunion all\nselect 'Care plan', 'No active care plans recorded', NULL, NULL::date, NULL\nwhere not exists (select 1 from data);",
