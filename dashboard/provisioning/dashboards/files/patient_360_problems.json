      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "healthcare-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "select p.golden_id as \"Golden ID\", string_agg(distinct trim(concat_ws(' ', p.first_name, p.last_name)), ' | ' order by trim(concat_ws(' ', p.first_name, p.last_name))) as \"Patient Name(s)\", min(p.birth_date)::date as \"Birth Date\", max(date_part('year', age(p.birth_date)))::int as \"Age\", max(p.gender) as \"Gender\", string_agg(distinct p.zip_code, ', ' order by p.zip_code) as \"ZIP Codes\", string_agg(distinct p.source_system, ', ' order by p.source_system) as \"Source Systems\", count(distinct p.id) as \"Linked Records\", coalesce((select rr.readmission_risk from analytics.readmission_risk rr where rr.golden_id = p.golden_id limit 1), 'low') as \"Readmission Risk\", max(e.start_date)::date as \"Last Visit Date\" from patients p left join encounters e on e.patient_id = p.id where p.golden_id = '${golden_id}' group by p.golden_id;",
          "refId": "A"
        }
      ]
    },
    {
