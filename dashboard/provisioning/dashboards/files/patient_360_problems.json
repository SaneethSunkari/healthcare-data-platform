      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "healthcare-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "with problem_rollup as (\n    select c.description as problem, max(c.onset_date) as last_seen\n    from conditions c\n    join patients p on p.id = c.patient_id\n    where p.golden_id = '${golden_id}'\n      and c.description is not null\n      and c.description !~* '(medication review due|full-time employment|part-time employment|not in labor force|employment status|social isolation|limited social contact|received higher education|educated to high school level|has a criminal record)'\n    group by c.description\n)\nselect count(*) from problem_rollup where last_seen >= current_date - interval '24 months';",
          "refId": "A"
        }
      ]
    },
