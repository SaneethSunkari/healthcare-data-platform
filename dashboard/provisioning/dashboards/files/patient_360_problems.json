        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "healthcare-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "with latest_labs as (select distinct on (coalesce(o.description, o.code)) coalesce(o.description, o.code) as lab_name, o.value_numeric, o.value_text, o.interpretation from observations o join patients p on p.id = o.patient_id where p.golden_id = '${golden_id}' and lower(coalesce(o.category, '')) like '%laboratory%' order by coalesce(o.description, o.code), o.effective_at desc nulls last), latest_vitals as (select distinct on (coalesce(o.description, o.code)) coalesce(o.description, o.code) as vital_name, o.value_numeric, o.value_text from observations o join patients p on p.id = o.patient_id where p.golden_id = '${golden_id}' and lower(coalesce(o.category, '')) like '%vital%' order by coalesce(o.description, o.code), o.effective_at desc nulls last), meds as (select count(distinct coalesce(m.description, m.code)) as current_meds from medications m join patients p on p.id = m.patient_id where p.golden_id = '${golden_id}' and (coalesce(m.status, 'active') not in ('stopped', 'cancelled', 'entered-in-error') or m.stop_date is null or m.stop_date >= current_date)), follow_up as (select current_date - max(e.start_date::date) as days_since_visit from encounters e join patients p on p.id = e.patient_id where p.golden_id = '${golden_id}'), risk as (select coalesce((select readmission_risk from analytics.readmission_risk where golden_id = '${golden_id}' limit 1), 'low') as readmission_risk) select count(*) from (select 1 where (select readmission_risk from risk) = 'high' union all select 1 where (select current_meds from meds) >= 10 union all select 1 from latest_labs where lab_name ilike 'Hemoglobin A1c%' and coalesce(value_numeric, 0) >= 6.5 union all select 1 from latest_vitals where vital_name = 'Systolic Blood Pressure' and coalesce(value_numeric, 0) >= 140 union all select 1 from latest_labs where lab_name ilike 'Cholesterol in LDL%' and coalesce(value_numeric, 0) >= 130 union all select 1 where coalesce((select days_since_visit from follow_up), 0) >= 180) alerts;",
          "refId": "A"
        }
      ]
    },
