      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "healthcare-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "with data as (\n    select\n        c.match_score as \"Score\",\n        c.left_patient_id as \"Left Source ID\",\n        trim(concat_ws(' ', l.first_name, l.last_name)) as \"Left Patient\",\n        c.right_patient_id as \"Right Source ID\",\n        trim(concat_ws(' ', r.first_name, r.last_name)) as \"Right Patient\",\n        l.birth_date::date as \"Birth Date\",\n        l.gender as \"Gender\",\n        coalesce(l.zip_code, r.zip_code) as \"ZIP\"\n    from patient_match_candidates c\n    join patients l on l.id = c.left_patient_id\n    join patients r on r.id = c.right_patient_id\n    where c.review_status = 'review needed'\n    order by c.match_score desc, l.birth_date desc nulls last\n    limit 15\n)\nselect * from data\nunion all\nselect NULL::numeric(4,3), 'No MPI review queue items', NULL, NULL, NULL, NULL::date, NULL, NULL\nwhere not exists (select 1 from data);",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
