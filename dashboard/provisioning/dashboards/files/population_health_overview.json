      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "healthcare-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "with data as (\n    with search_results as (\n        select\n            p.golden_id,\n            string_agg(\n                distinct trim(concat_ws(' ', p.first_name, p.last_name)),\n                ' | '\n                order by trim(concat_ws(' ', p.first_name, p.last_name))\n            ) as patient_names,\n            min(p.birth_date)::date as birth_date,\n            max(p.gender) as gender,\n            string_agg(distinct p.zip_code, ', ' order by p.zip_code) as zip_codes,\n            count(distinct p.id) as linked_records,\n            max(e.start_date)::date as last_visit\n        from patients p\n        left join encounters e on e.patient_id = p.id\n        where p.golden_id is not null\n          and '${patient_search}' <> ''\n          and (\n            p.golden_id ilike '%' || '${patient_search}' || '%'\n            or p.id ilike '%' || '${patient_search}' || '%'\n            or trim(concat_ws(' ', p.first_name, p.last_name)) ilike '%' || '${patient_search}' || '%'\n            or p.last_name ilike '%' || '${patient_search}' || '%'\n            or p.zip_code ilike '%' || '${patient_search}' || '%'\n            or coalesce(p.source_system, '') ilike '%' || '${patient_search}' || '%'\n            or to_char(p.birth_date, 'YYYY-MM-DD') ilike '%' || '${patient_search}' || '%'\n            or to_char(p.birth_date, 'MM/DD/YYYY') ilike '%' || '${patient_search}' || '%'\n          )\n        group by p.golden_id\n    )\n    select\n        s.golden_id,\n        s.patient_names,\n        s.birth_date,\n        s.gender,\n        s.zip_codes,\n        s.linked_records,\n        s.last_visit,\n        coalesce(rr.readmission_risk, 'low') as readmission_risk\n    from search_results s\n    left join analytics.readmission_risk rr on rr.golden_id = s.golden_id\n    order by\n        case\n            when s.golden_id = '${patient_search}' then 0\n            when s.golden_id ilike '${patient_search}%' then 1\n            else 2\n        end,\n        s.last_visit desc nulls last,\n        s.patient_names\n    limit 15\n)\nselect * from data\nunion all\nselect NULL, 'Start with a name, DOB, ZIP, source ID, or golden ID', NULL::date, NULL, NULL, NULL::bigint, NULL::date, NULL\nwhere '${patient_search}' = ''\nunion all\nselect NULL, 'No patients matched that search', NULL::date, NULL, NULL, NULL::bigint, NULL::date, NULL\nwhere '${patient_search}' <> '' and not exists (select 1 from data);",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Patient Search Results",
      "type": "table"
