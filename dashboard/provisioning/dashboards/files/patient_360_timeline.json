          "rawSql": "with data as (select coalesce(dr.effective_at, dr.issued_at)::date as \"Date\", dr.description as \"Report\", initcap(coalesce(dr.status, 'final')) as \"Status\", left(coalesce(dr.report_text, ''), 140) as \"Excerpt\" from diagnostic_reports dr join patients p on p.id = dr.patient_id where p.golden_id = '${golden_id}' order by coalesce(dr.effective_at, dr.issued_at) desc nulls last, dr.description limit 20) select * from data union all select NULL::date, 'No diagnostic reports recorded', NULL, NULL where not exists (select 1 from data);",
