          "rawSql": "with data as (select distinct pr.performed_start::date as \"Date\", pr.description as \"Procedure\", initcap(coalesce(pr.status, 'completed')) as \"Status\" from procedures pr join patients p on p.id = pr.patient_id where p.golden_id = '${golden_id}' order by \"Date\" desc nulls last, \"Procedure\" limit 40) select * from data union all select NULL::date, 'No procedures recorded', NULL where not exists (select 1 from data);",
          "refId": "A"
        }
      ]
    }
  ],
