        "showHeader": true,
        "footer": {
          "show": false,
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "healthcare-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "with data as (\nselect\n    e.start_date::date as \"Date\",\n    coalesce(e.encounter_type, 'Encounter') as \"Care Setting\",\n    coalesce(e.provider, 'Unknown') as \"Provider\",\n    coalesce(e.cost, 0)::numeric(12,2) as \"Cost\",\n    case\n        when coalesce(e.encounter_type, '') ilike '%emergency%' or coalesce(e.encounter_type, '') ilike '%urgent%' then 'Acute'\n        when coalesce(e.encounter_type, '') ilike '%admission%' or coalesce(e.encounter_type, '') ilike '%inpatient%' then 'Hospital'\n        else 'Ambulatory'\n    end as \"Acuity\"\nfrom encounters e\njoin patients p on p.id = e.patient_id\nwhere p.golden_id = '${golden_id}'\norder by e.start_date desc nulls last\nlimit 25\n)\nselect * from data\nunion all\nselect NULL::date, 'No recent encounters recorded', NULL, NULL::numeric, NULL\nwhere not exists (select 1 from data);",
          "refId": "A"
        }
      ]
    },
